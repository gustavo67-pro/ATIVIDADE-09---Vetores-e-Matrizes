programa {
  funcao inicio() {
    cadeia cor[3]
    escreva("LEITURA MANUAL\n")
    escreva("Escreva a primeira cor:\n")
    leia(cor[0])
    escreva("Escreva a segunda cor:\n")
    leia(cor[1])
    escreva("Escreva a terceira cor:\n")
    leia(cor[2])
    escreva("ORDEM:\n",cor[2],"\n",cor[1],"\n",cor[0])
  }
}
